# Render structured summary sections with headers and highlighted text
echo "$DAY_SUMMARY" | python3 -c "
import sys, json
sections = json.loads(sys.stdin.read().strip())
for i, sec in enumerate(sections):
    header = sec.get('header', '')
    body = sec.get('body', '')
    if not body:
        continue
    html = ''
    if header:
        html += f'<div style=\"font-family:DM Mono,monospace;font-size:10px;color:#9a9088;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px;{\"margin-top:18px;\" if i > 0 else \"\"}\">{header}</div>'
    html += f'<p style=\"font-size:15px;color:#0a0a0f;margin:0 0 4px 0;line-height:1.75;\">{body}</p>'
    print(html)
" >> "$OUT_DIR/email.html"

