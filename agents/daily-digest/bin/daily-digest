        $CAL_TODAY_HTML
      </div>
    </div>

    <!-- Email -->
    <div style="margin-bottom:36px;">
      <div style="font-family:'DM Mono',monospace;font-size:11px;color:#9a9088;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px;">02 — Email Highlights</div>
      <div style="background:#ffffff;border-radius:10px;padding:24px;border:1.5px solid #e8e3da;">
        $EMAIL_HTML
      </div>
    </div>

    <!-- Digital Hygiene -->
    <div style="margin-bottom:36px;">
      <div style="font-family:'DM Mono',monospace;font-size:11px;color:#9a9088;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px;">03 — Digital Hygiene</div>
      <div style="background:#ffffff;border-radius:10px;padding:24px;border:1.5px solid #e8e3da;">
        $BROWSER_HTML
      </div>
    </div>

    <!-- Active Projects -->
    <div style="margin-bottom:36px;">
      <div style="font-family:'DM Mono',monospace;font-size:11px;color:#9a9088;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px;">04 — Active Projects</div>
      <div style="background:#ffffff;border-radius:10px;padding:24px;border:1.5px solid #e8e3da;">
        $TASKS_HTML
      </div>
    </div>

    <!-- Tomorrow Look-Ahead -->
    <div style="margin-bottom:36px;">
      <div style="font-family:'DM Mono',monospace;font-size:11px;color:#9a9088;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px;">05 — Tomorrow: $TOMORROW_DISPLAY</div>
      <div style="background:#ffffff;border-radius:10px;padding:24px;border:1.5px solid #e8e3da;">
        $CAL_TOMORROW_HTML
      </div>
    </div>

    <!-- Evening Reflection -->
    <div style="margin-bottom:36px;">
