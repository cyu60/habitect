# ---- Save preview copy ----
cp "$OUT_DIR/email.html" /tmp/digest-preview.html 2>/dev/null || true

# ---- Output: Terminal ----
cat "$OUT_DIR/digest.md"

# ---- Output: Obsidian ----
if [ "$SKIP_OBSIDIAN" = false ]; then
  OBSIDIAN_FILE="$OBSIDIAN_VAULT/Daily Notes/$OBSIDIAN_DATE.md"
  if [ -f "$OBSIDIAN_FILE" ]; then
    echo "" >> "$OBSIDIAN_FILE"
    echo "---" >> "$OBSIDIAN_FILE"
    echo "" >> "$OBSIDIAN_FILE"
    cat "$OUT_DIR/digest.md" >> "$OBSIDIAN_FILE"
    echo "[Obsidian] Appended to: $OBSIDIAN_FILE"
  else
    cat "$OUT_DIR/digest.md" > "$OBSIDIAN_FILE"
    echo "[Obsidian] Created: $OBSIDIAN_FILE"
  fi
fi

# ---- Output: Notion ----
if [ "$SKIP_NOTION" = false ] && [ "$DRY_RUN" = false ]; then
  echo "[Notion] Creating digest page..."
  MEETINGS_DB="255ab088-064e-800e-b27d-f9bf93741625"
  cd /Users/china/codeDev/notion-management && bash -c "
    source bin/notion-config.sh
    BODY='{\"parent\":{\"database_id\":\"$MEETINGS_DB\"},\"properties\":{\"Name\":{\"title\":[{\"text\":{\"content\":\"Evening Digest — $DISPLAY_DATE\"}}]},\"Event Type\":{\"select\":{\"name\":\"Daily Standup\"}},\"Event Date\":{\"date\":{\"start\":\"$DATE\"}}}}'
    RESULT=\$(notion_request POST '/pages' \"\$BODY\")
    PAGE_ID=\$(echo \"\$RESULT\" | python3 -c 'import json,sys; print(json.load(sys.stdin)[\"id\"])' 2>/dev/null || echo '')
    if [ -n \"\$PAGE_ID\" ]; then
      echo \"  Created page: \$PAGE_ID\"
    else
      echo '  Failed to create page'
    fi
  " 2>/dev/null || echo "  [Notion] Failed"
fi

# ---- Output: Email ----
if [ "$SKIP_EMAIL" = false ] && [ "$DRY_RUN" = false ]; then
  echo "[Email] Sending digest to $PERSONAL..."
  EMAIL_BODY_HTML=$(cat "$OUT_DIR/email.html")
  gog gmail send \
    --to "$PERSONAL" \
    --subject "Evening Digest — $DISPLAY_DATE" \
    --body-html "$EMAIL_BODY_HTML" \
    --account "$PERSONAL" \
    --force 2>/dev/null && echo "  Sent!" || echo "  Failed to send"
fi

echo ""
echo "=== Done ==="
