    </table>

    <!-- Day Summary -->
    <div style="margin-bottom:36px;padding:20px 24px;background:rgba(28,63,220,.04);border-radius:10px;border-left:3px solid #4a6aff;">
      <p style="font-size:15px;color:#0a0a0f;margin:0;line-height:1.7;">$DAY_SUMMARY</p>
    </div>

